# Скопируйте в .env и заполните (локально). На Render задайте в Dashboard.

# Обязательно в продакшене
SECRET_KEY=your-secret-key-here
DEBUG=True

# MySQL (если пусто — используется SQLite)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Почта (сброс пароля, рассылка). На Render: EMAIL_HOST_PASSWORD в секретах.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Доп. доверенные origin для CSRF (через запятую), например https://mysite.onrender.com
CSRF_TRUSTED_ORIGINS=

# Опционально: явный домен для django.contrib.sites (облако)
SITE_DOMAIN=
